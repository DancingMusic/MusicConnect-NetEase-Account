{
  "name": "@dancingmusic/music-connect-netease-account",
  "version": "0.1.0",
  "description": "Desktop NetEase Cloud Music account connector for DancingMusic with host-owned secure cookie capture.",
  "repository": { "type": "git", "url": "https://github.com/DancingMusic/MusicConnect-NetEase-Account.git" },
  "homepage": "https://dancingmusic.github.io/MusicConnect-NetEase-Account/",
  "bugs": { "url": "https://github.com/DancingMusic/MusicConnect-NetEase-Account/issues" },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --target es2020 --no-splitting",
    "prepublishOnly": "npm run build",
    "test": "vitest run --reporter=verbose"
  },
  "keywords": [
    "dancingmusic",
    "music-connector",
    "netease",
    "netease-cloud-music",
    "account",
    "desktop"
  ],
  "license": "MIT",
  "peerDependencies": {
    "@dancingmusic/music-connect": ">=0.2.0"
  },
  "overrides": {
    "esbuild": "0.28.1"
  },
  "optionalDependencies": {
    "@esbuild/linux-x64": "0.28.1",
    "@rollup/rollup-linux-x64-gnu": "4.60.4",
    "@rolldown/binding-linux-x64-gnu": "1.1.5"
  },
  "devDependencies": {
    "@dancingmusic/music-connect": "github:DancingMusic/MusicConnect#b90bcabdeff428eb1b1bf5a772c40f2c5e4f5013",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.10"
  }
}
